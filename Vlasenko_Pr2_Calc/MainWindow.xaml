<Window x:Class="Vlasenko_Pr2_Calc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vlasenko_Pr2_Calc"
        mc:Ignorable="d"
        Title="Ultra_Caclculator 3000" Height="450" Width="350" MaxHeight="450" MaxWidth="350">
    <Grid x:Name="a">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="TBI" Grid.ColumnSpan="4" Height="35" FontSize="20" FontFamily="Comic Sans MS" HorizontalContentAlignment="Right" VerticalAlignment="Bottom" Background="Pink" IsReadOnly="True"/>
        <TextBox x:Name="TBH" Grid.ColumnSpan="4" Height="35" FontSize="20" FontFamily="Comic Sans MS" HorizontalContentAlignment="Right" VerticalAlignment="Top" Background="LightPink" IsReadOnly="True"/>

        <Button x:Name="SKOBKAL" Grid.Row="1" Content="(" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="SKOBKAR" Grid.Row="1" Grid.Column="1" Content=")" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="POW" Grid.Row="1" Grid.Column="2" Content="^" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="DElenie" Grid.Row="1" Grid.Column="3" Content="/" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="One" Grid.Row="2" Grid.Column="0" Content="1" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Two" Grid.Row="2" Grid.Column="1" Content="2" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Three" Grid.Row="2" Grid.Column="2" Content="3" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Umnozit" Grid.Row="2" Grid.Column="3" Content="*" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Four" Grid.Row="3" Grid.Column="0" Content="4" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Five" Grid.Row="3" Grid.Column="1" Content="5" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Six" Grid.Row="3" Grid.Column="2" Content="6" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Minus" Grid.Row="3" Grid.Column="3" Content="-" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Seven" Grid.Row="4" Grid.Column="0" Content="7" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Eight" Grid.Row="4" Grid.Column="1" Content="8" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Nine" Grid.Row="4" Grid.Column="2" Content="9" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Plus" Grid.Row="4" Grid.Column="3" Content="+" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Delete" Grid.Row="5" Grid.Column="0" Content="C" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Zero" Grid.Row="5" Grid.Column="1" Content="0" FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="DOUBLE" Grid.Row="5" Grid.Column="2" Content="." FontFamily="Comic Sans MS" FontSize="30"/>
        <Button x:Name="Ravenstvo" Grid.Row="5" Grid.Column="3" Content="=" FontFamily="Comic Sans MS" FontSize="30"/>
    </Grid>
</Window>
